FROM node:20-alpine
WORKDIR /app

# Install dependencies and build
COPY package*.json ./
RUN npm install
COPY . .
RUN npx tsc && npx vite build && chmod -R 755 /app

# The server.mjs uses APP_ROOT env var to know where the files are
ENV APP_ROOT=/app/dist
ENV PORT=80

EXPOSE 80

CMD ["node", "server.mjs"]
