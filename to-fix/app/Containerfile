# WASM build stage
FROM rust:1-slim AS wasm-builder
WORKDIR /repo
RUN apt-get update \
    && apt-get install -y --no-install-recommends lld \
    && rm -rf /var/lib/apt/lists/* \
    && rustup target add wasm32-unknown-unknown
COPY src/core ./src/core
RUN CARGO_TARGET_WASM32_UNKNOWN_UNKNOWN_LINKER=wasm-ld \
    cargo rustc --manifest-path src/core/Cargo.toml --target wasm32-unknown-unknown --release --lib --crate-type=cdylib

# Build stage
FROM node:20-slim AS builder
WORKDIR /app
ARG VITE_SRV_URL=http://localhost:8000
ARG VITE_TRAIN_MODE=false
ENV VITE_SRV_URL=${VITE_SRV_URL}
ENV VITE_TRAIN_MODE=${VITE_TRAIN_MODE}
COPY src/app/package*.json ./
RUN npm install
COPY src/app/ .
COPY --from=wasm-builder /repo/src/core/target/wasm32-unknown-unknown/release/handwriting_core.wasm public/wasm/handwriting_core.wasm
RUN mkdir -p /models
RUN npx tsc && npx vite build

# Runtime stage
FROM node:20-slim
WORKDIR /app
COPY --from=builder /app/dist /app
COPY src/app/release-server.mjs /server.mjs
COPY src/app/entrypoint.sh /entrypoint.sh
ENV APP_ROOT=/app
RUN chmod -R a+rX /app \
    && chmod +x /server.mjs \
    && chmod +x /entrypoint.sh
EXPOSE 80
ENTRYPOINT ["/entrypoint.sh"]
